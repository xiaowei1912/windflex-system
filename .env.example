# =============================================================================
# Windflex System - Environment Variables Template
# Copy this file to .env and fill in the values.
# =============================================================================

# ==================== 板子配置 ====================
# 测试板的固定 IP 地址（必填）
BOARD_IP=192.168.1.100
BOARD_SSH_PORT=22
BOARD_SSH_USER=root
# SSH 认证方式：使用密钥（推荐）或密码
BOARD_SSH_KEY_PATH=/root/.ssh/id_rsa
BOARD_SSH_PASSWORD=
# SSH 密钥所在宿主机目录（挂载到容器）
SSH_KEY_DIR=/root/.ssh

# ==================== 电源配置 ====================
# 电源型号：Non-programmable（非编程电源）或 DLX-30V10AMP（可编程电源）
POWER_MODEL=Non-programmable
# 串口设备路径（连接电源或板子串口）
SERIAL_DEVICE=/dev/ttyUSB0
# 串口波特率
BAUD_RATE=9600

# ==================== Git 平台配置 ====================
# Git 平台类型：github 或 gitlab
GIT_PLATFORM=github
# 测试用例仓库 URL
GIT_URL=https://github.com/xiaowei1912/board-test-cases.git
# Git 用户名
GIT_USER=xiaowei1912
# GitHub Personal Access Token 或 GitLab Personal Access Token
GIT_TOKEN=your_git_token_here

# ==================== 数据库配置 ====================
DB_PASSWORD=windflex_db_password

# ==================== 服务端口配置 ====================
HARDWARE_SERVICE_PORT=8000
JENKINS_HTTP_PORT=8080
JENKINS_JNLP_PORT=50000

# ==================== 其他配置 ====================
# 时区
TZ=Asia/Shanghai
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
